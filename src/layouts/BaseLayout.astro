---
/**
 * BaseLayout — the HTML shell shared by every page.
 *
 * Handles:
 *   - SEO meta tags (title, description, Open Graph, Twitter Card)
 *   - Schema.org JSON-LD (passed per-page via the `schema` prop)
 *   - Google Fonts preconnect + stylesheet link
 *   - Dark-mode restoration (inline script in <head> — runs before
 *     first paint to prevent a flash of the wrong theme)
 *   - Fade-up IntersectionObserver (deferred script in <body>)
 */

import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Absolute canonical URL — defaults to the current page URL */
  canonical?: string;
  /** Absolute URL for the OG image */
  ogImage?: string;
  /** Schema.org JSON-LD object to embed in a <script type="application/ld+json"> */
  schema?: Record<string, unknown> | Record<string, unknown>[];
  /** Show the reading progress bar (blog posts only) */
  showProgress?: boolean;
}

const {
  title,
  description = 'Designer, maker, occasional writer.',
  canonical,
  ogImage,
  schema,
  showProgress = false,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://mcespo.com');
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage ?? new URL('/og-default.jpg', siteUrl).href;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Primary SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Marvin Céspedes" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Feeds -->
  <link rel="alternate" type="application/rss+xml" title="Marvin Céspedes" href="/feed.xml" />

  <!-- Google Fonts — four weights, two styles, loaded once -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&family=Caveat+Brush&family=Caveat:wght@400..600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Schema.org JSON-LD — structured data passed per-page -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <!--
    Dark mode: read localStorage BEFORE first paint to avoid a
    flash of the wrong theme. Uses is:inline so Astro doesn't
    bundle or defer this — it must run synchronously in <head>.
  -->
  <script is:inline>
    (function () {
      try {
        var s = JSON.parse(localStorage.getItem('mcespo.tweaks') || '{}');
        var dark;
        if (s.darkMode === 'dark') {
          dark = true;
        } else if (s.darkMode === 'light') {
          dark = false;
        } else {
          // Auto: system preference first, then time of day (7 pm – 7 am = dark)
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            dark = true;
          } else if (window.matchMedia('(prefers-color-scheme: light)').matches) {
            dark = false;
          } else {
            var h = new Date().getHours();
            dark = h >= 19 || h < 7;
          }
        }
        if (dark)          document.documentElement.classList.add('dark');
        if (s.hideGutter)  document.documentElement.classList.add('hide-gutter');
      } catch (_) {}
    })();
  </script>
</head>

<body>
  <!-- Reading progress bar — only rendered on blog posts -->
  {showProgress && (
    <div class="progress" aria-hidden="true">
      <div class="bar" id="progress-bar"></div>
    </div>
  )}

  <slot />

  <!--
    Fade-up scroll animation — adds .in to .fade-up elements
    as they enter the viewport. Uses passive scroll + IO so
    it never blocks the main thread.
  -->
  <script>
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
    );
    document.querySelectorAll('.fade-up').forEach((el) => io.observe(el));
  </script>

  <!-- Reading progress bar script — only runs when the bar element exists -->
  <script>
    const bar = document.getElementById('progress-bar');
    if (bar) {
      function updateProgress() {
        const h = document.documentElement;
        const total = h.scrollHeight - h.clientHeight;
        const pct = total > 0 ? Math.min(100, Math.max(0, (h.scrollTop / total) * 100)) : 0;
        bar.style.width = pct + '%';
      }
      document.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }
  </script>
</body>
</html>
